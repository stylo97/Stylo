<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1, user-scalable=no">
<title>Stylos · Registro de salón</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-database-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-auth-compat.js"></script>
<style>
  :root{
    --crema:#0B0B0D;
    --carbon:#F5F5F5;
    --terracota:#FF0080;
    --terracota-d:#CC0066;
    --salvia:#FF0080;
    --oro:#FF0080;
    --linea:#2A2A2E;
    --blanco:#19191C;
  }
  *{box-sizing:border-box; -webkit-tap-highlight-color:transparent;}
  html,body{margin:0;padding:0;height:100%;}
  body{
    font-family:'Helvetica Neue',Arial,sans-serif;
    background:var(--crema);
    color:var(--carbon);
    min-height:100vh;
    display:flex;
    flex-direction:column;
  }
  .util{font-family:'Helvetica Neue',Arial,sans-serif;}

  header.top{
    padding:22px 24px 16px;
    display:flex;
    align-items:baseline;
    justify-content:space-between;
    border-bottom:1px solid var(--linea);
  }
  .brand{
    font-size:22px;
    letter-spacing:0.14em;
    text-transform:uppercase;
    font-weight:700;
    color:var(--terracota-d);
  }
  .brand small{
    display:block;
    font-family:'Helvetica Neue',Arial,sans-serif;
    font-size:11px;
    letter-spacing:0.08em;
    color:#9a9aa0;
    text-transform:none;
    margin-top:2px;
  }
  .crumbs{
    font-family:'Helvetica Neue',Arial,sans-serif;
    font-size:13px;
    color:#9a9aa0;
  }
  .crumbs b{color:var(--terracota-d);}

  main{
    flex:1;
    display:flex;
    flex-direction:column;
    align-items:center;
    padding:28px 18px 100px;
    width:100%;
  }
  .screen{
    width:100%;
    max-width:560px;
    display:none;
  }
  .screen.active{display:block; animation:rise .25s ease;}
  @keyframes rise{from{opacity:0; transform:translateY(8px);} to{opacity:1; transform:none;}}

  h1.title{
    font-size:26px;
    margin:0 0 6px;
    color:var(--carbon);
  }
  p.sub{
    font-family:'Helvetica Neue',Arial,sans-serif;
    color:#9a9aa0;
    margin:0 0 26px;
    font-size:14.5px;
  }

  .grid{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:14px;
  }
  .grid.single{grid-template-columns:1fr;}

  button.opt{
    font-family:inherit;
    background:#FFFFFF;
    border:1.5px solid #FFFFFF;
    border-radius:14px;
    padding:20px 16px;
    font-size:18px;
    color:#FF0080;
    text-align:left;
    cursor:pointer;
    transition:border-color .15s, transform .1s, box-shadow .15s;
    box-shadow:0 1px 2px rgba(0,0,0,0.3);
  }
  button.opt:active{transform:scale(0.97);}
  button.opt:hover{border-color:#FF0080; box-shadow:0 4px 10px rgba(255,0,128,0.25);}
  button.opt .meta{
    display:block;
    font-family:'Helvetica Neue',Arial,sans-serif;
    font-size:12px;
    color:#8a8a8a;
    margin-top:4px;
  }
  button.opt.precio{display:flex; justify-content:space-between; align-items:center;}
  button.opt .price{
    font-family:'Helvetica Neue',Arial,sans-serif;
    font-weight:700;
    color:#CC0066;
    font-size:16px;
    white-space:nowrap;
    margin-left:10px;
  }

  .cover{
    text-align:center;
    padding-top:6vh;
  }
  .cover .mark{
    width:64px;height:64px;border-radius:50%;
    background:#FFFFFF;
    margin:0 auto 20px;
    display:flex;align-items:center;justify-content:center;
    color:#FF0080; font-size:26px; font-weight:700;
  }
  .cover h1{font-size:30px; margin-bottom:4px;}
  .cover p{font-family:'Helvetica Neue',Arial,sans-serif; color:#9a9aa0; margin-bottom:34px;}
  .cover .grid{max-width:420px;margin:0 auto;}
  .cover button.opt{font-size:19px; padding:26px 18px; text-align:center;}

  .backbar{
    display:flex; align-items:center; gap:10px;
    margin-bottom:18px;
  }
  .back{
    font-family:'Helvetica Neue',Arial,sans-serif;
    background:none; border:none; color:var(--terracota-d);
    font-size:14px; cursor:pointer; padding:6px 0;
    display:flex; align-items:center; gap:4px;
  }

  .confirm-card{
    background:var(--blanco);
    border:1.5px solid var(--linea);
    border-radius:16px;
    padding:24px;
    margin-bottom:20px;
  }
  .row{
    display:flex; justify-content:space-between;
    padding:10px 0; border-bottom:1px solid var(--linea);
    font-family:'Helvetica Neue',Arial,sans-serif; font-size:15px;
  }
  .row:last-child{border-bottom:none;}
  .row span:first-child{color:#9a9aa0;}
  .row span:last-child{font-weight:600;}
  .row.total span:last-child{color:#FF0080; font-size:20px;}

  .pago{display:flex; gap:10px; margin-bottom:20px; flex-wrap:wrap;}
  .pago button{flex:1 1 40%;}
  .pago button{
    flex:1; font-family:'Helvetica Neue',Arial,sans-serif;
    padding:12px; border-radius:10px; border:1.5px solid #FFFFFF;
    background:#FFFFFF; color:#FF0080; cursor:pointer; font-size:14px;
  }
  .pago button.sel{border-color:#FF0080; background:#FF0080; color:#FFFFFF; font-weight:700;}

  .cta{
    width:100%;
    background:#FFFFFF;
    color:#FF0080;
    border:none;
    padding:18px;
    border-radius:14px;
    font-family:'Helvetica Neue',Arial,sans-serif;
    font-size:17px; font-weight:700;
    cursor:pointer;
    letter-spacing:0.02em;
  }
  .cta:active{background:#f0f0f0;}
  .cta:disabled{background:#3a3a3e; color:#7a7a80; cursor:not-allowed;}

  .toast{
    position:fixed; bottom:24px; left:50%; transform:translateX(-50%);
    background:#FFFFFF; color:#111111;
    padding:14px 22px; border-radius:30px;
    font-family:'Helvetica Neue',Arial,sans-serif; font-size:14px;
    box-shadow:0 8px 24px rgba(0,0,0,0.4);
    opacity:0; pointer-events:none; transition:opacity .25s, transform .25s;
  }
  .toast.show{opacity:1; transform:translateX(-50%) translateY(-6px);}

  footer.bottombar{
    position:fixed; bottom:0; left:0; right:0;
    background:var(--blanco);
    border-top:1px solid var(--linea);
    padding:10px 16px;
    display:flex; gap:10px; justify-content:center;
    font-family:'Helvetica Neue',Arial,sans-serif;
  }
  .bbtn{
    flex:1; max-width:220px;
    background:none; border:1.5px solid #FF0080;
    border-radius:10px; padding:10px 12px;
    font-size:13.5px; color:#FF0080; cursor:pointer;
  }
  .bbtn.primary{background:#FFFFFF; color:#FF0080; border-color:#FFFFFF;}
  .bbtn.danger{background:none; color:#ff4d4d; border-color:#ff4d4d;}

  .empty{
    font-family:'Helvetica Neue',Arial,sans-serif;
    color:#7a7a80; text-align:center; padding:30px 10px;
  }
  table.regs{width:100%; border-collapse:collapse; font-family:'Helvetica Neue',Arial,sans-serif; font-size:12.5px;}
  table.regs th, table.regs td{padding:8px 6px; border-bottom:1px solid var(--linea); text-align:left;}
  table.regs th{color:var(--terracota-d); font-weight:700; font-size:11px; text-transform:uppercase; letter-spacing:0.03em;}
  table.regs td.nombre{font-weight:700; color:var(--carbon);}
  table.regs td.monto{font-weight:700; color:#FF0080;}

  .admin-overlay{
    display:none;
    position:fixed; inset:0;
    background:rgba(0,0,0,0.6);
    align-items:center; justify-content:center;
    z-index:1000;
    padding:20px;
  }
  .admin-overlay.show{display:flex;}
  .admin-box{
    background:var(--blanco);
    border:1px solid var(--linea);
    border-radius:16px;
    padding:24px;
    width:100%; max-width:340px;
  }
  .admin-box h2{
    margin:0 0 16px; font-size:18px; color:var(--carbon);
  }
  .admin-box input{
    width:100%; padding:14px; border-radius:10px;
    border:1.5px solid var(--linea);
    background:var(--crema); color:var(--carbon);
    font-size:16px; margin-bottom:16px;
  }
  .admin-actions{display:flex; justify-content:flex-end; gap:10px; align-items:center;}
</style>
</head>
<body>

<header class="top">
  <img src="data:image/jpeg;base64," alt="Estilos Sala de Belleza" style="height:38px; width:auto; display:block;">
  <div class="crumbs" id="crumbs"></div>
</header>

<main>

  <!-- PORTADA -->
  <section class="screen active cover" id="s-cover">
    <img src="data:image/jpeg;base64," alt="Estilos Sala de Belleza" style="width:200px; height:auto; margin:0 auto 28px; display:block;">
    <p>Selecciona el salón para empezar</p>
    <div class="grid" id="salones-grid"></div>
    <div style="margin-top:40px;">
      <button class="back" onclick="pedirClave()">Acceso administrador →</button>
    </div>
  </section>

  <!-- PERSONAL -->
  <section class="screen" id="s-personal">
    <div class="backbar"><button class="back" onclick="goTo('cover')">‹ Volver</button></div>
    <h1 class="title">¿Quién eres?</h1>
    <p class="sub">Selecciona tu usuario</p>
    <div class="grid" id="personal-grid"></div>
  </section>

  <!-- CATEGORIA -->
  <section class="screen" id="s-categoria">
    <div class="backbar"><button class="back" onclick="goTo('personal')">‹ Volver</button></div>
    <h1 class="title">¿Qué tipo de servicio?</h1>
    <p class="sub" id="cat-sub"></p>
    <div class="grid single" id="categoria-grid"></div>
    <div style="margin-top:24px; text-align:center;">
      <button class="back" onclick="showMiRegistro()">Ver mi registro de hoy →</button>
    </div>
  </section>

  <!-- SERVICIO -->
  <section class="screen" id="s-servicio">
    <div class="backbar"><button class="back" onclick="goTo('categoria')">‹ Volver</button></div>
    <h1 class="title">¿Cuál servicio?</h1>
    <p class="sub" id="serv-sub"></p>
    <div class="grid single" id="servicio-grid"></div>
  </section>

  <!-- PRODUCTO (venta libre) -->
  <section class="screen" id="s-producto">
    <div class="backbar"><button class="back" onclick="goTo('categoria')">‹ Volver</button></div>
    <h1 class="title">Venta de producto</h1>
    <p class="sub">Escribe el producto y el valor cobrado</p>
    <div class="confirm-card">
      <p class="sub" style="margin-bottom:8px;">Producto</p>
      <input type="text" id="prod-nombre" placeholder="Ej: Champú anticaspa" style="width:100%; padding:14px; border-radius:10px; border:1.5px solid var(--linea); background:var(--crema); color:var(--carbon); font-size:16px; margin-bottom:16px;">
      <p class="sub" style="margin-bottom:8px;">Valor cobrado</p>
      <input type="number" id="prod-precio" placeholder="Ej: 15000" inputmode="numeric" style="width:100%; padding:14px; border-radius:10px; border:1.5px solid var(--linea); background:var(--crema); color:var(--carbon); font-size:16px;">
    </div>
    <button class="cta" onclick="confirmarProducto()">Continuar</button>
  </section>

  <!-- PEINADO (servicio libre) -->
  <section class="screen" id="s-peinado">
    <div class="backbar"><button class="back" onclick="goTo('categoria')">‹ Volver</button></div>
    <h1 class="title">Peinado</h1>
    <p class="sub">Escribe el nombre del peinado y el valor cobrado</p>
    <div class="confirm-card">
      <p class="sub" style="margin-bottom:8px;">Peinado</p>
      <input type="text" id="peinado-nombre" placeholder="Ej: Trenzas" style="width:100%; padding:14px; border-radius:10px; border:1.5px solid var(--linea); background:var(--crema); color:var(--carbon); font-size:16px; margin-bottom:16px;">
      <p class="sub" style="margin-bottom:8px;">Valor cobrado</p>
      <input type="number" id="peinado-precio" placeholder="Ej: 12000" inputmode="numeric" style="width:100%; padding:14px; border-radius:10px; border:1.5px solid var(--linea); background:var(--crema); color:var(--carbon); font-size:16px;">
    </div>
    <button class="cta" onclick="confirmarPeinado()">Continuar</button>
  </section>

  <!-- PRECIO DIFERENTE (servicio libre dentro de una categoría) -->
  <section class="screen" id="s-personalizado">
    <div class="backbar"><button class="back" onclick="goTo('servicio')">‹ Volver</button></div>
    <h1 class="title" id="custom-titulo">Precio diferente</h1>
    <p class="sub">Escribe el nombre del servicio y el valor cobrado</p>
    <div class="confirm-card">
      <p class="sub" style="margin-bottom:8px;">Servicio</p>
      <input type="text" id="custom-nombre" placeholder="Ej: Manicure con diseño" style="width:100%; padding:14px; border-radius:10px; border:1.5px solid var(--linea); background:var(--crema); color:var(--carbon); font-size:16px; margin-bottom:16px;">
      <p class="sub" style="margin-bottom:8px;">Valor cobrado</p>
      <input type="number" id="custom-precio" placeholder="Ej: 35000" inputmode="numeric" style="width:100%; padding:14px; border-radius:10px; border:1.5px solid var(--linea); background:var(--crema); color:var(--carbon); font-size:16px;">
    </div>
    <button class="cta" onclick="confirmarPersonalizado()">Continuar</button>
  </section>

  <!-- LARGO / VARIANTE -->
  <section class="screen" id="s-largo">
    <div class="backbar"><button class="back" onclick="goTo('servicio')">‹ Volver</button></div>
    <h1 class="title" id="largo-title">Detalle</h1>
    <p class="sub">Selecciona la opción</p>
    <div class="grid single" id="largo-grid"></div>
  </section>

  <!-- CONFIRMAR -->
  <section class="screen" id="s-confirmar">
    <div class="backbar"><button class="back" onclick="goTo(state.servicio && state.servicio.esProducto ? 'producto' : (state.servicio && state.servicio.esPeinado ? 'peinado' : 'servicio'))">‹ Volver</button></div>
    <div class="confirm-card">
      <div class="row"><span>Salón</span><span id="cf-salon"></span></div>
      <div class="row"><span>Personal</span><span id="cf-personal"></span></div>
      <div class="row"><span>Servicio</span><span id="cf-servicio"></span></div>
      <div class="row"><span>Fecha</span><span id="cf-fecha"></span></div>
      <div class="row total"><span>Precio</span><span id="cf-precio"></span></div>
    </div>
    <p class="sub" style="margin-bottom:10px;">Método de pago</p>
    <div class="pago" id="pago-grid">
      <button onclick="setPago('Efectivo')">Efectivo</button>
      <button onclick="setPago('Transferencia')">Transferencia</button>
      <button onclick="setPago('QR')">QR</button>
    </div>
    <button class="cta" id="btn-guardar" onclick="guardarRegistro()" disabled>Guardar registro</button>
  </section>

  <!-- MI REGISTRO (vista del empleado) -->
  <section class="screen" id="s-mi-registro">
    <div class="backbar"><button class="back" onclick="goTo('categoria')">‹ Volver</button></div>
    <h1 class="title">Mi registro de hoy</h1>
    <p class="sub" id="mireg-sub"></p>
    <div id="mireg-table"></div>
    <div class="confirm-card" id="mireg-resumen" style="margin-top:16px;"></div>
  </section>

  <!-- HISTORIAL -->
  <section class="screen" id="s-historial">
    <div class="backbar"><button class="back" onclick="goTo('cover')">‹ Volver</button></div>
    <h1 class="title">Registros</h1>
    <p class="sub" id="hist-sub"></p>
    <div style="margin-bottom:16px;">
      <input type="date" id="hist-fecha" style="padding:12px; border-radius:10px; border:1.5px solid var(--linea); background:var(--blanco); color:var(--carbon); font-size:15px;" onchange="renderHistorial()">
    </div>
    <div id="hist-resumen" style="margin-bottom:16px;"></div>
    <div id="hist-table"></div>
  </section>

</main>

<!-- MODAL CLAVE ADMIN -->
<div id="admin-overlay" class="admin-overlay">
  <div class="admin-box">
    <h2>Acceso administrador</h2>
    <input type="password" id="admin-input" inputmode="numeric" placeholder="Clave de administrador" autocomplete="off">
    <input type="number" id="admin-porcentaje" inputmode="numeric" placeholder="% de arriendo (manicure/pedicure/depilación)" style="margin-bottom:0;">
    <div class="admin-actions">
      <button class="back" onclick="cerrarModalAdmin()">Cancelar</button>
      <button class="cta" style="padding:12px 18px; width:auto;" onclick="verificarClave()">Entrar</button>
    </div>
  </div>
</div>

<footer class="bottombar" id="footer-bar" style="display:none;">
  <button class="bbtn" onclick="showHistorial()">Ver registros</button>
  <button class="bbtn primary" onclick="exportarExcel()">Descargar Excel</button>
  <button class="bbtn danger" onclick="borrarTodosLosRegistros()">Borrar todo</button>
</footer>

<div class="toast" id="toast"></div>

