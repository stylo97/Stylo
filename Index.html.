/* ---------- CONFIRMAR ---------- */
function renderConfirmar(){
  state.pago = null;
  document.getElementById('cf-salon').textContent = state.salon.nombre;
  document.getElementById('cf-personal').textContent = state.personal.nombre;
  document.getElementById('cf-servicio').textContent = state.servicio.nombre + (state.largo? ' · '+state.largo.nombre : '');
  document.getElementById('cf-fecha').textContent = new Date().toLocaleDateString('es-CO', {day:'2-digit', month:'2-digit', year:'numeric'});
  document.getElementById('cf-precio').textContent = fmt(state.precio);
  document.querySelectorAll('#pago-grid button').forEach(b=>b.classList.remove('sel'));
  document.getElementById('btn-guardar').disabled = true;
}

function setPago(metodo){
  state.pago = metodo;
  document.querySelectorAll('#pago-grid button').forEach(b=>{
    b.classList.toggle('sel', b.textContent===metodo);
  });
  document.getElementById('btn-guardar').disabled = false;
}

/* ---------- CÁLCULO DE ARRIENDO (comisión del salón) ---------- */
function calcComisionPct(personalNombre, catId){
  if(personalNombre === 'SILVIA') return 0; // Silvia se queda el 100%, no se descuenta nada
  const cat = CATEGORIAS.find(c=>c.id===catId);
  if(cat && cat.comisionAdmin) return PORC_SALON; // manicure, pedicure, depilación
  return 50; // resto de servicios: arriendo fijo del 50%
}

function guardarRegistro(){
  const now = new Date();
  const iso = now.getFullYear()+'-'+String(now.getMonth()+1).padStart(2,'0')+'-'+String(now.getDate()).padStart(2,'0');
  const catId = state.servicio && state.servicio.cat;
  const comisionPct = calcComisionPct(state.personal.nombre, catId);
  const comisionValor = Math.round(state.precio * (comisionPct/100));
  const registro = {
    ts: now.getTime(),
    hora: now.toLocaleTimeString('es-CO', {hour:'2-digit', minute:'2-digit'}),
    fecha: now.toLocaleDateString('es-CO'),
    isoFecha: iso,
    salon: state.salon.nombre,
    personal: state.personal.nombre,
    servicio: state.servicio.nombre + (state.largo? ' ('+state.largo.nombre+')':''),
    precio: state.precio,
    pago: state.pago,
    esProducto: !!(state.servicio && state.servicio.esProducto),
    comisionPct: comisionPct,
    comisionValor: comisionValor
  };
  const nombrePersonal = registro.personal, nombreServicio = registro.servicio;
  let confirmado = false;
  setTimeout(()=>{
    if(!confirmado) toast('Guardando "'+nombreServicio+'"... sigue esperando confirmación, revisa tu conexión');
  }, 6000);
  registrosRef.push(registro)
    .then(()=>{ confirmado = true; toast('Registrado: '+nombrePersonal+' · '+nombreServicio); })
    .catch(err=>{
      confirmado = true;
      console.error('Error al guardar registro en Firebase:', err);
      toast('No se pudo guardar: '+err.message);
    });

  // vuelve al menú de selección de persona para evitar registrar bajo el usuario equivocado
  state.personal=null; state.categoria=null; state.servicio=null; state.largo=null; state.precio=null; state.pago=null;
  renderPersonal();
  goTo('personal');
}

/* ---------- HISTORIAL ---------- */
function isoHoy(){
  const now = new Date();
  return now.getFullYear()+'-'+String(now.getMonth()+1).padStart(2,'0')+'-'+String(now.getDate()).padStart(2,'0');
}

function fechaMatch(r, iso){
  if(r.isoFecha) return r.isoFecha === iso;
  // registros viejos sin isoFecha: comparar con fecha visible dd/mm/yyyy
  const [y,m,d] = iso.split('-');
  return r.fecha === d+'/'+m+'/'+y || r.fecha === Number(d)+'/'+Number(m)+'/'+y;
}

function getComision(r){
  if(typeof r.comisionValor === 'number') return r.comisionValor;
  // registros antiguos guardados antes de este cambio: se calculan con la regla vigente
  const pct = r.personal === 'SILVIA' ? 0 : PORC_SALON;
  return Math.round(r.precio * (pct/100));
}

function showHistorial(){
  const input = document.getElementById('hist-fecha');
  if(!input.value) input.value = isoHoy();
  renderHistorial();
  goTo('historial');
}

function renderHistorial(){
  const iso = document.getElementById('hist-fecha').value || isoHoy();
  const deDia = REGISTROS.filter(r=>fechaMatch(r, iso));
  document.getElementById('hist-sub').textContent = deDia.length + ' registro(s) ese día · ' + REGISTROS.length + ' en total';

  // Resumen por empleado (total del día y arriendo del salón)
  const porEmpleado = {};
  deDia.forEach(r=>{
    if(!porEmpleado[r.personal]) porEmpleado[r.personal] = {total:0, arriendo:0};
    porEmpleado[r.personal].total += r.precio;
    porEmpleado[r.personal].arriendo += getComision(r);
  });
  const empleados = Object.keys(porEmpleado);
  let resumenHtml = '';
  if(empleados.length){
    let filas = empleados.map(nombre=>{
      const total = porEmpleado[nombre].total;
      const arriendo = porEmpleado[nombre].arriendo;
      const neto = total - arriendo;
      return '<tr><td class="nombre">'+nombre+'</td><td>'+fmt(total)+'</td><td>'+fmt(arriendo)+'</td><td class="monto">'+fmt(neto)+'</td></tr>';
    }).join('');
    resumenHtml = '<table class="regs"><thead><tr><th>Personal</th><th>Total día</th><th>Arriendo</th><th>Le queda</th></tr></thead><tbody>'+filas+'</tbody></table>';
  }
  document.getElementById('hist-resumen').innerHTML = resumenHtml;

  const cont = document.getElementById('hist-table');
  if(deDia.length===0){
    cont.innerHTML = '<p class="empty">No hay registros para esta fecha.</p>';
  } else {
    let rows = deDia.slice().reverse().map((r)=>{
      return '<tr><td>'+r.hora+'</td><td>'+r.fecha+'</td><td>'+r.salon+'</td><td class="nombre">'+r.personal+'</td><td>'+r.servicio+'</td><td class="monto">'+fmt(r.precio)+'</td><td>'+r.pago+'</td></tr>';
    }).join('');
    cont.innerHTML = '<table class="regs"><thead><tr><th>Hora</th><th>Fecha</th><th>Salón</th><th>Personal</th><th>Servicio</th><th>Precio</th><th>Pago</th></tr></thead><tbody>'+rows+'</tbody></table>';
  }
}

function borrarTodosLosRegistros(){
  if(!confirm('¿Borrar TODOS los registros? Esta acción no se puede deshacer.')) return;
  if(!confirm('Confirma de nuevo: se borrará todo el historial de todos los dispositivos. ¿Continuar?')) return;
  registrosRef.remove()
    .then(()=>toast('Todos los registros fueron borrados'))
    .catch(()=>toast('No se pudo borrar: revisa tu conexión'));
}

/* ---------- MI REGISTRO (vista empleado) ---------- */
function renderMiRegistro(){
  const iso = isoHoy();
  const mios = REGISTROS.filter(r=>r.personal===state.personal.nombre && r.salon===state.salon.nombre && fechaMatch(r, iso));
  document.getElementById('mireg-sub').textContent = state.personal.nombre + ' · ' + state.salon.nombre + ' · hoy';

  const cont = document.getElementById('mireg-table');
  if(mios.length===0){
    cont.innerHTML = '<p class="empty">Aún no has registrado nada hoy.</p>';
  } else {
    let rows = mios.slice().reverse().map(r=>
      '<tr><td>'+r.hora+'</td><td>'+r.servicio+'</td><td class="monto">'+fmt(r.precio)+'</td><td>'+r.pago+'</td></tr>'
    ).join('');
    cont.innerHTML = '<table class="regs"><thead><tr><th>Hora</th><th>Servicio</th><th>Precio</th><th>Pago</th></tr></thead><tbody>'+rows+'</tbody></table>';
  }

  const bruto = mios.reduce((s,r)=>s+r.precio,0);
  const comisionSalon = mios.reduce((s,r)=>s+getComision(r),0);
  const neto = bruto - comisionSalon;
  document.getElementById('mireg-resumen').innerHTML =
    '<div class="row"><span>Total del día</span><span>'+fmt(bruto)+'</span></div>'+
    '<div class="row"><span>Arriendo</span><span>'+fmt(comisionSalon)+'</span></div>'+
    '<div class="row total"><span>Te queda</span><span>'+fmt(neto)+'</span></div>';
}

function showMiRegistro(){
  renderMiRegistro();
  goTo('mi-registro');
}

/* ---------- EXPORTAR A EXCEL (UN ARCHIVO POR DÍA) ---------- */
function exportarExcel(){
  if(REGISTROS.length===0){ toast('No hay registros para exportar'); return; }

  // Agrupar registros por fecha
  const porFecha = {};
  REGISTROS.forEach(r=>{
    if(!porFecha[r.fecha]) porFecha[r.fecha] = [];
    porFecha[r.fecha].push(r);
  });

  const fechas = Object.keys(porFecha);

  fechas.forEach((fecha, i)=>{
    const regsDia = porFecha[fecha];
    const data = [
      ['HORA','FECHA','SALÓN','PERSONAL','SERVICIO','PRECIO','METODO PAGO','TIPO','ARRIENDO','LE QUEDA'],
      ...regsDia.map(r=>{
        const arriendo = getComision(r);
        return [r.hora, r.fecha, r.salon, r.personal, r.servicio, r.precio, r.pago, r.esProducto?'Producto':'Servicio', arriendo, r.precio-arriendo];
      })
    ];
    const ws = XLSX.utils.aoa_to_sheet(data);
    ws['!cols'] = [{wch:8},{wch:12},{wch:14},{wch:12},{wch:28},{wch:10},{wch:14},{wch:10},{wch:10},{wch:10}];
    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, ws, 'REGISTROS');

    // Convertir fecha (formato es-CO, p.ej. 30/6/2026) a algo apto para nombre de archivo
    const fechaArchivo = fecha.replace(/\//g, '-');

    // Pequeño retraso entre descargas para que el navegador no las bloquee
    setTimeout(()=>{
      XLSX.writeFile(wb, 'Registros_Stylos_'+fechaArchivo+'.xlsx');
      if(i === fechas.length - 1){
        toast(fechas.length + ' archivo(s) Excel descargado(s)');
      }
    }, i * 400);
  });
}

