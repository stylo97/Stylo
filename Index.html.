  document.body.innerHTML = '<div style="padding:40px 20px;text-align:center;font-family:Arial,sans-serif;color:#F5F5F5;">'
    + '<h2 style="color:#FF0080;">No se pudo conectar a la nube</h2>'
    + '<p>Los archivos de Firebase no cargaron. Revisa tu conexión a internet, desactiva bloqueadores de anuncios/privacidad para este sitio, y recarga la página.</p>'
    + '</div>';
  throw new Error('Firebase SDK no se cargó (revisa la conexión a internet o bloqueadores de scripts).');
}

firebase.initializeApp(firebaseConfig);
const db = firebase.database();
const auth = firebase.auth();
const registrosRef = db.ref('registros');
const porcRef = db.ref('config/porcSalon');

/* ---------- ESTADO ---------- */
let state = { salon:null, personal:null, categoria:null, servicio:null, largo:null, precio:null, pago:null };
let REGISTROS = JSON.parse(localStorage.getItem('stylos_registros') || '[]'); // copia local mientras carga la nube
let PORC_SALON = parseFloat(localStorage.getItem('stylos_porc_salon') || '50');
const ADMIN_PIN = '1977';
let adminUnlocked = false;
let conectado = false;
let sesionLista = false;
let rtdbConectado = false;

// Esto detecta si el dispositivo realmente logra conectarse al servidor de la base de datos
// (distinto a si los archivos de Firebase cargaron). Si la red bloquea firebaseio.com,
// esto nunca pasará a true aunque el resto de la app funcione normal.
db.ref('.info/connected').on('value', snap=>{
  rtdbConectado = snap.val() === true;
  if(!rtdbConectado){
    console.warn('Sin conexión al servidor de la base de datos (firebaseio.com). Revisa si la red/wifi del dispositivo lo está bloqueando.');
  }
});
setTimeout(()=>{
  if(!rtdbConectado){
    toast('Sin conexión a la base de datos: revisa tu red/wifi');
  }
}, 6000);

// Refresca solo la pantalla que el usuario tiene abierta en este momento, sin moverlo de pantalla
function refrescarPantallaActual(){
  const activo = document.querySelector('.screen.active');
  if(!activo) return;
  if(activo.id === 's-historial') renderHistorial();
  if(activo.id === 's-mi-registro' && state.personal) renderMiRegistro();
}

function conectarDatos(){
  registrosRef.on('value', snapshot=>{
    const val = snapshot.val() || {};
    REGISTROS = Object.keys(val).map(key=>Object.assign({_key:key}, val[key]));
    REGISTROS.sort((a,b)=>(a.ts||0)-(b.ts||0));
    localStorage.setItem('stylos_registros', JSON.stringify(REGISTROS));
    if(!conectado){ conectado = true; }
    refrescarPantallaActual();
  }, error=>{
    console.error('Error al leer registros de Firebase:', error);
    toast('No se pudieron cargar los registros: '+error.message);
  });

  porcRef.on('value', snapshot=>{
    const val = snapshot.val();
    if(typeof val === 'number'){
      PORC_SALON = val;
      localStorage.setItem('stylos_porc_salon', String(val));
      refrescarPantallaActual();
    }
  }, error=>{
    console.error('Error al leer porcentaje de Firebase:', error);
  });
}

// La app se identifica sola ante Firebase (sin pedir nada a las chicas) para poder leer/escribir.
// Esto evita que cualquier persona en internet pueda acceder a la base de datos sin pasar por la app.
auth.onAuthStateChanged(user=>{
  if(user && !sesionLista){
    sesionLista = true;
    conectarDatos();
  }
});
auth.signInAnonymously().catch(err=>{
  console.error('Error de autenticación', err);
  toast('No se pudo conectar a la nube (revisa tu conexión a internet)');
});

function pedirClave(){
  document.getElementById('admin-input').value = '';
  document.getElementById('admin-porcentaje').value = PORC_SALON;
  document.getElementById('admin-overlay').classList.add('show');
  setTimeout(()=>document.getElementById('admin-input').focus(), 50);
}

function cerrarModalAdmin(){
  document.getElementById('admin-overlay').classList.remove('show');
}

function verificarClave(){
  const clave = document.getElementById('admin-input').value;
  if(clave.trim() === ADMIN_PIN){
    adminUnlocked = true;
    const p = parseFloat(document.getElementById('admin-porcentaje').value);
    if(!isNaN(p) && p>=0 && p<=100){
      PORC_SALON = p;
      localStorage.setItem('stylos_porc_salon', String(p));
      porcRef.set(p).catch(()=>{ toast('No se pudo guardar el % en la nube (revisa tu conexión)'); });
    }
    cerrarModalAdmin();
    document.getElementById('footer-bar').style.display = 'flex';
    showHistorial();
  } else {
    toast('Clave incorrecta');
  }
}

document.addEventListener('DOMContentLoaded', ()=>{
  const input = document.getElementById('admin-input');
  if(input){
    input.addEventListener('keydown', e=>{ if(e.key==='Enter') verificarClave(); });
  }
});

const fmt = n => '$' + n.toLocaleString('es-CO');

function goTo(name){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById('s-'+name).classList.add('active');
  document.getElementById('footer-bar').style.display = (name==='cover' && adminUnlocked) ? 'flex' : 'none';
  updateCrumbs(name);
}

function updateCrumbs(name){
  const c = document.getElementById('crumbs');
  let parts = [];
  if(state.salon) parts.push(state.salon.nombre);
  if(state.personal) parts.push(state.personal.nombre);
  c.innerHTML = parts.map(p=>'<b>'+p+'</b>').join(' · ');
}

function toast(msg){
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'), 1800);
}

/* ---------- RENDER PORTADA ---------- */
function renderSalones(){
  const g = document.getElementById('salones-grid');
  g.innerHTML = '';
  SALONES.forEach(s=>{
    const b = document.createElement('button');
    b.className='opt';
    b.style.textAlign='center';
    b.textContent = s.nombre;
    b.onclick = ()=>{ state.salon=s; state.personal=null; renderPersonal(); goTo('personal'); };
    g.appendChild(b);
  });
}

/* ---------- PERSONAL ---------- */
function renderPersonal(){
  const g = document.getElementById('personal-grid');
  g.innerHTML = '';
  PERSONAL.filter(p=>p.salon===state.salon.id).forEach(p=>{
    const b = document.createElement('button');
    b.className='opt';
    b.style.textAlign='center';
    b.textContent = p.nombre;
    b.onclick = ()=>{ state.personal=p; renderCategorias(); goTo('categoria'); };
    g.appendChild(b);
  });
}

/* ---------- CATEGORIAS ---------- */
function renderCategorias(){
  document.getElementById('cat-sub').textContent = state.personal.nombre + ' · ' + state.salon.nombre;
  const g = document.getElementById('categoria-grid');
  g.innerHTML = '';
  const esSilvia = state.personal.nombre === 'SILVIA';
  [...CATEGORIAS]
    .filter(c=> !c.soloSilvia || esSilvia)
    .sort((a,b)=>a.orden-b.orden)
    .forEach(c=>{
      const b = document.createElement('button');
      b.className='opt';
      b.textContent = c.nombre;
      b.onclick = ()=>{
        state.categoria=c;
        if(c.id==='C06'){
          document.getElementById('prod-nombre').value='';
          document.getElementById('prod-precio').value='';
          goTo('producto');
        } else if(c.libre){
          document.getElementById('peinado-nombre').value='';
          document.getElementById('peinado-precio').value='';
          goTo('peinado');
        } else {
          renderServicios();
          goTo('servicio');
        }
      };
      g.appendChild(b);
    });
}

/* ---------- SERVICIOS ---------- */
function renderServicios(){
  document.getElementById('serv-sub').textContent = state.categoria.nombre;
  const g = document.getElementById('servicio-grid');
  g.innerHTML = '';
  SERVICIOS.filter(s=>s.cat===state.categoria.id).forEach(s=>{
    const b = document.createElement('button');
    b.className='opt precio';
    const precioBase = PRECIOS[s.id]._ !== undefined ? PRECIOS[s.id]._ : Object.values(PRECIOS[s.id])[0];
    b.innerHTML = '<span>'+s.nombre+(s.tipoLargo? '<span class="meta">Toca para elegir variante</span>':'')+'</span><span class="price">'+(s.tipoLargo? 'desde '+fmt(precioBase) : fmt(precioBase))+'</span>';
    b.onclick = ()=>{
      state.servicio = s;
      if(s.tipoLargo){
        renderLargo();
        goTo('largo');
      } else {
        state.largo = null;
        state.precio = PRECIOS[s.id]._;
        renderConfirmar();
        goTo('confirmar');
      }
    };
    g.appendChild(b);
  });
  if(state.categoria.precioDiferente){
    const b = document.createElement('button');
    b.className='opt';
    b.style.textAlign='center';
    b.textContent = 'Precio diferente';
    b.onclick = ()=>{
      document.getElementById('custom-titulo').textContent = state.categoria.nombre + ' · Precio diferente';
      document.getElementById('custom-nombre').value='';
      document.getElementById('custom-precio').value='';
      goTo('personalizado');
    };
    g.appendChild(b);
  }
}

/* ---------- LARGO / VARIANTE ---------- */
function renderLargo(){
  const opts = state.servicio.tipoLargo === 'LARGO' ? LARGOS : DEPILACION;
  document.getElementById('largo-title').textContent = state.servicio.nombre;
  const g = document.getElementById('largo-grid');
  g.innerHTML = '';
  opts.forEach(o=>{
    const b = document.createElement('button');
    b.className='opt precio';
    const precio = PRECIOS[state.servicio.id][o.id];
    b.innerHTML = '<span>'+o.nombre+'</span><span class="price">'+fmt(precio)+'</span>';
    b.onclick = ()=>{
      state.largo = o;
      state.precio = precio;
      renderConfirmar();
      goTo('confirmar');
    };
    g.appendChild(b);
  });
}

/* ---------- PRODUCTO (solo Silvia) ---------- */
function confirmarProducto(){
  const nombre = document.getElementById('prod-nombre').value.trim();
  const precio = parseInt(document.getElementById('prod-precio').value, 10);
  if(!nombre){ toast('Escribe el nombre del producto'); return; }
  if(!precio || precio<=0){ toast('Escribe un valor válido'); return; }
  state.servicio = {id:'PROD', nombre:'Producto Silvia: '+nombre, esProducto:true, cat:'C06'};
  state.largo = null;
  state.precio = precio;
  renderConfirmar();
  goTo('confirmar');
}

/* ---------- PEINADO (servicio libre) ---------- */
function confirmarPeinado(){
  const nombre = document.getElementById('peinado-nombre').value.trim();
  const precio = parseInt(document.getElementById('peinado-precio').value, 10);
  if(!nombre){ toast('Escribe el nombre del peinado'); return; }
  if(!precio || precio<=0){ toast('Escribe un valor válido'); return; }
  state.servicio = {id:'PEIN', nombre:'Peinado: '+nombre, esPeinado:true, cat:'C08'};
  state.largo = null;
  state.precio = precio;
  renderConfirmar();
  goTo('confirmar');
}

/* ---------- PRECIO DIFERENTE (servicio libre dentro de una categoría con precios fijos) ---------- */
function confirmarPersonalizado(){
  const nombre = document.getElementById('custom-nombre').value.trim();
  const precio = parseInt(document.getElementById('custom-precio').value, 10);
  if(!nombre){ toast('Escribe el nombre del servicio'); return; }
  if(!precio || precio<=0){ toast('Escribe un valor válido'); return; }
  state.servicio = {id:'CUSTOM', nombre: state.categoria.nombre+': '+nombre, esCustom:true, cat: state.categoria.id};
  state.largo = null;
